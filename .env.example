# ── STORAGE ──────────────────────────────────────────────────
# Bucket público para assets das fichas (imagens SVG/PNG)
STORAGE_BUCKET_ASSETS=worksheet-assets

# Bucket privado para PDFs gerados
STORAGE_BUCKET_PDFS=worksheet-pdfs

# Tempo de expiração dos links de PDF (em segundos) — padrão: 86400 = 24h
PDF_LINK_EXPIRY_SECONDS=86400

# ── BACKEND (FastAPI ou Node/Express) ────────────────────────
# Porta do servidor de API
API_PORT=8000

# Ambiente: development | production
NODE_ENV=development

# Chave secreta para assinar tokens JWT internos (gere com: openssl rand -hex 32)
SECRET_KEY=sua-chave-secreta-aqui-nunca-use-este-valor-em-producao

# ── GERADOR DE PDF ───────────────────────────────────────────
# Caminho local para cache de PDFs durante desenvolvimento
PDF_CACHE_DIR=./tmp/pdfs

# Timeout de geração de PDF em segundos
PDF_TIMEOUT_SECONDS=30

# ── FRONTEND (React) ─────────────────────────────────────────
# Prefixo VITE_ para variáveis expostas ao browser
VITE_SUPABASE_URL=https://pzpzqnhdkfkuwzoujwjj.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InB6cHpxbmhka2ZrdXd6b3Vqd2pqIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzIyMjAzNzYsImV4cCI6MjA4Nzc5NjM3Nn0.4vi__f52n0VpWrGBhnMx3SYBEFi8PkiWGMDAYyqQT1A
VITE_API_URL=http://localhost:8000

# ── LGPD / SEGURANÇA ─────────────────────────────────────────
# Email do DPO (Encarregado de Proteção de Dados)
DPO_EMAIL=dpo@geraficha.com.br

# ── DESENVOLVIMENTO ──────────────────────────────────────────
# Nível de log: debug | info | warning | error
LOG_LEVEL=debug
